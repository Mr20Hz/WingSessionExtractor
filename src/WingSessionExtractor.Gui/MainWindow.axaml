<Window
    x:Class="WingSessionExtractor.Gui.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Wing Session Extractor"
    Width="820"
    Height="860"
    MinWidth="640"
    MinHeight="600"
    WindowStartupLocation="CenterScreen">
  <ScrollViewer>
    <Grid Margin="32" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="14">
      <StackPanel Grid.Row="0" Spacing="4">
        <TextBlock FontSize="26" FontWeight="SemiBold" Text="Wing Session Extractor" />
        <TextBlock
            Opacity="0.7"
            Text="Run a finite, manually started workflow for WING-LIVE sessions." />
      </StackPanel>

      <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <StackPanel Grid.Column="0" Spacing="5">
          <TextBlock Text="Input directory" />
          <TextBox
              IsEnabled="{Binding CanEdit}"
              Text="{Binding InputDirectory}"
              Watermark="Select the WING recording directory" />
        </StackPanel>
        <Button
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Command="{Binding PickInputCommand}"
            Content="Browse…" />
      </Grid>

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <StackPanel Grid.Column="0" Spacing="5">
          <TextBlock Text="Output directory" />
          <TextBox
              IsEnabled="{Binding CanEdit}"
              Text="{Binding OutputDirectory}"
              Watermark="Select where channel WAV files will be written" />
        </StackPanel>
        <Button
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Command="{Binding PickOutputCommand}"
            Content="Browse…" />
      </Grid>

      <Border
          Grid.Row="3"
          Padding="12"
          BorderBrush="#66808080"
          BorderThickness="1"
          CornerRadius="4">
        <StackPanel Spacing="8">
          <CheckBox
              Content="Create Logic Pro project after extraction"
              IsChecked="{Binding EnableLogicProjectCreation}"
              IsEnabled="{Binding CanToggleLogicProjectCreation}" />
          <TextBlock
              Opacity="0.7"
              Text="{Binding LogicCapability.Explanation}"
              TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel Grid.Column="0" Spacing="5">
              <TextBlock Text="Logic template project" />
              <TextBox
                  IsEnabled="{Binding CanEditLogicSettings}"
                  Text="{Binding LogicTemplatePath}"
                  Watermark="Select a .logicx template project" />
            </StackPanel>
            <Button
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Command="{Binding PickLogicTemplateCommand}"
                Content="Browse…" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel Grid.Column="0" Spacing="5">
              <TextBlock Text="Logic project output directory" />
              <TextBox
                  IsEnabled="{Binding CanEditLogicSettings}"
                  Text="{Binding LogicProjectOutputDirectory}"
                  Watermark="Select where Logic projects will be created" />
            </StackPanel>
            <Button
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Command="{Binding PickLogicProjectOutputCommand}"
                Content="Browse…" />
          </Grid>
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="4" Spacing="5">
        <TextBlock FontWeight="SemiBold" Text="Workflow steps" />
        <ItemsControl ItemsSource="{Binding WorkflowSteps}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Margin="8,2" Text="{Binding DisplayName}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <StackPanel Grid.Row="5" Spacing="6">
        <TextBlock FontWeight="SemiBold" Text="Current step" />
        <TextBlock Text="{Binding CurrentStep}" />
        <TextBlock Opacity="0.7" Text="Overall progress" />
        <ProgressBar Height="12" Minimum="0" Maximum="100" Value="{Binding OverallProgress}" />
        <TextBlock Opacity="0.7" Text="Current step progress" />
        <ProgressBar Height="12" Minimum="0" Maximum="100" Value="{Binding StepProgress}" />
      </StackPanel>

      <StackPanel Grid.Row="6" Spacing="5">
        <TextBlock FontWeight="SemiBold" Text="Status" />
        <TextBlock MinHeight="22" Text="{Binding StatusText}" TextWrapping="Wrap" />
        <TextBox
            Height="100"
            AcceptsReturn="True"
            IsReadOnly="True"
            Text="{Binding StatusLogText}"
            TextWrapping="Wrap" />
      </StackPanel>

      <Border
          Grid.Row="7"
          Padding="12"
          Background="#22D13438"
          BorderBrush="#D13438"
          BorderThickness="1"
          CornerRadius="4"
          IsVisible="{Binding HasError}">
        <TextBlock Foreground="#D13438" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
      </Border>

      <Border
          Grid.Row="8"
          Padding="12"
          BorderBrush="#66808080"
          BorderThickness="1"
          CornerRadius="4"
          IsVisible="{Binding HasFinalSummary}">
        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Final summary" />
          <TextBlock Text="{Binding FinalSummary}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <StackPanel
          Grid.Row="9"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
          Spacing="8">
        <Button Command="{Binding CancelCommand}" Content="Cancel" />
        <Button Classes="accent" Command="{Binding StartCommand}" Content="Start Workflow" />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Window>
